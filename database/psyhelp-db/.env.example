# =====================================================================
# .env.example — скопіюйте в .env та заповніть реальними значеннями.
# ФАЙЛ .env НЕ КОМІТИТИ В GIT (додайте до .gitignore).
# =====================================================================

# ---------------------------------------------------------------------
# Підключення до PostgreSQL
# ---------------------------------------------------------------------
# Для міграцій (власник схеми)
PSYHELP_DB_URL=postgresql://psyhelp_owner:REPLACE_ME@localhost:5432/psyhelp

# Для backend (application-роль)
PSYHELP_APP_DB_URL=postgresql://psyhelp_app:REPLACE_ME@localhost:5432/psyhelp?sslmode=require

# Пул з'єднань Node.js
PSYHELP_DB_POOL_MIN=2
PSYHELP_DB_POOL_MAX=10
PSYHELP_DB_IDLE_TIMEOUT=30000

# ---------------------------------------------------------------------
# Шифрування
# ---------------------------------------------------------------------
# Ключ для pgp_sym_encrypt(). Мінімум 32 байти.
# Згенерувати: openssl rand -base64 48
PSYHELP_ENCRYPTION_KEY=REPLACE_WITH_OPENSSL_RAND_BASE64_48

# ---------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------
# Секрет для підпису access-токенів (HS256). Мінімум 32 байти.
JWT_ACCESS_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_48
JWT_ACCESS_TTL=15m

# Секрет для refresh-токенів (окремий від access!)
JWT_REFRESH_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_48
JWT_REFRESH_TTL=30d

# ---------------------------------------------------------------------
# Зовнішні сервіси
# ---------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# SMTP для сповіщень (опціонально)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="PsyHelp <noreply@psyhelp.local>"

# ---------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
